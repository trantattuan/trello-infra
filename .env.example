# PostgreSQL
POSTGRES_DB=trello
POSTGRES_USER=trello
POSTGRES_PASSWORD=trello_secret

# Redis
REDIS_URL=redis://redis:6379

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false

# JWT
JWT_SECRET=change_this_to_a_random_64_char_secret
JWT_EXPIRES_IN=7d

# App
DATABASE_URL=postgresql://trello:trello_secret@postgres:5432/trello
API_PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost
